# =============================================
# YouStart AI - .gitignore
# =============================================

# Arquivos de ambiente (NUNCA commitar chaves de API)
.env
.env.local
.env.production
.env.development

# Dependências e builds
node_modules/
dist/
build/

# Arquivos temporários do sistema
.DS_Store
Thumbs.db
*.log

# Editor configs
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Cache
.npm
yarn-error.log
pnpm-lock.yaml

# Arquivos gerados pelo Vercel
.vercel
.vercel.json.bak

# =============================================
# Observação:
# O arquivo .env.example deve ser commitado (é seguro)
# O arquivo .env NUNCA deve ser commitado
# =============================================